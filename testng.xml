<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Orion CRM Test Automation Suite">
    
    <!-- Register the custom ExtentReports listener -->
    <listeners>
        <listener class-name="com.orion.utils.ExtentReportManager"/>
    </listeners>
    
    <!-- Define the test execution block -->
    <test name="Functional Login Regression Tests">
        <classes>
            <class name="com.orion.tests.LoginTest"/>
        </classes>
    </test>

    <!-- Database vs UI Validation Tests -->
    <test name="Database Validation Tests">
        <classes>
            <class name="com.orion.tests.DatabaseValidationTest"/>
        </classes>
    </test>

    <!-- Pivot Report Table Validation Tests -->
    <test name="Pivot Report Tests">
        <classes>
            <class name="com.orion.tests.PivotReportTest"/>
            <class name="com.orion.tests.PivotReportPositiveTableTest"/>
            <class name="com.orion.tests.FetchPositiveTotalTest"/>
        </classes>
    </test>

    <!-- Sales Pipeline Tests -->
    <test name="Sales Pipeline Tests">
        <classes>
            <class name="com.orion.tests.TestScenario"/>
        </classes>
    </test>
</suite>
